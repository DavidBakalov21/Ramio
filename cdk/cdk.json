{
  "app": "npx ts-node --prefer-ts-exts bin/ramio.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules",
      "cdk.out"
    ]
  },
  "context": {
    "submissionsBucketName": "ramio-file-storage",
    "materialsBucketName": "ramio-materials",
    "imagesBucketName": "ramio-images",
    "codeBuildProvisionLanguages": ["Python", "NodeJs", "Java", "DotNet", "Cpp"],
    "apiIamUserName": "file-manager",
    "frontendUrl": "http://localhost:3000",
    "backendCallbackUrl": "http://localhost:3333/auth/callback",
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"],
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true
  }
}
